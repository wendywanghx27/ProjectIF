# Raspberry Pi SMB/CIFS share used by docker-compose
PI_SHARE_HOST=project-if-rpi.local
PI_SHARE_NAME=pic_shared
PI_SHARE_USER=pi
PI_SHARE_PASSWORD=change-me
PI_SHARE_VERS=3.0

# Host paths used by docker-compose volume mounts
MASK_OUTPUT_DIR_HOST=./masked
STATE_DIR_HOST=./state

# Pipeline behavior
CHECK_INTERVAL_SECONDS=60
FILE_STABLE_SECONDS=30
PROMPT_TEXT=plant
LOG_LEVEL=INFO
IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.bmp,.tif,.tiff
DEVICE=gpu-required
